# Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
PUBLIC_API_BASE_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/estate_admin

# JWT
JWT_ACCESS_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=10d

# Refresh token cookie (httpOnly — not exposed in API response)
REFRESH_TOKEN_COOKIE_NAME=estate_refresh_token
COOKIE_DOMAIN=
COOKIE_SECURE=
COOKIE_SAME_SITE=lax

# Security
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
EXPRESS_TRUST_PROXY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Media Storage — local | cloudinary | r2
MEDIA_STORAGE_PROVIDER=local
MAX_IMAGE_SIZE_MB=60
MAX_DOCUMENT_SIZE_MB=60
MAX_PROPERTY_MEDIA=10
MAX_PROPERTY_DOCUMENTS=30
IMAGE_WEBP_QUALITY=80
IMAGE_MAX_WIDTH=1920

# Cloudinary (when MEDIA_STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare R2 (when MEDIA_STORAGE_PROVIDER=r2)
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=

# Admin Seed (used by scripts/seedAdmin.js only)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@estateadmin.com
SEED_ADMIN_PASSWORD=ChangeMe@123
